# ─── OpenClaw Hire Console — Environment Configuration ───
# Copy this file to .env and customize for your deployment.

# ─── Required ────────────────────────────────────────────
# Secret key for JWT token signing. MUST change in production.
SECRET_KEY=change-me-in-production

# MySQL database connection
DB_HOST=localhost
DB_NAME=openclaw_hire
DB_USER=openclaw
DB_PASSWORD=your-db-password

# ─── Public URL ──────────────────────────────────────────
# Base URL of your deployment (used for CORS, uploads, Origin headers)
SITE_BASE_URL=https://your-domain.com

# ─── HXA Hub ─────────────────────────────────────────────
# HXA Connect Hub for real-time bot communication.
# Default: public hub at www.ucai.net/connect (free for open-source users)
HXA_HUB_URL=https://www.ucai.net/connect

# ─── AI Services (Optional) ─────────────────────────────
# Configure one or both providers. Instances will use whichever is set.

# Anthropic / Claude
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=sk-ant-...

# OpenAI / GPT (also used by Codex)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# Whisper speech-to-text service (host-side, for marketplace skill)
# WHISPER_SERVICE_URL=http://172.17.0.1:8019

# ─── Application Paths ───────────────────────────────────
# Project root directory (defaults to current working directory)
# OPENCLAW_HOME=/opt/openclaw-hire

# ─── Frontend ────────────────────────────────────────────
# API base URL (for frontend to reach backend)
# VITE_API_BASE=http://localhost:8012
# VITE_BASE_PATH=/
